# IoTBreaker - Environment Variables
# Copy this file to .env and fill in your values.
# Usage: cp env.example .env && source .env

# ---- API Keys ----
# Shodan API key (https://account.shodan.io/)
SHODAN_API_KEY=

# NIST NVD API key for higher rate limits (https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=

# ---- Runtime Overrides ----
# Connection timeout in seconds (default: 5)
IOTBREAKER_TIMEOUT=5

# Number of concurrent threads (default: 100)
IOTBREAKER_THREADS=100

# Output directory for reports (default: ./reports)
IOTBREAKER_OUTPUT=./reports
